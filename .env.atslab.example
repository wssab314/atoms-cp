ATOMS_APP_IMAGE=atoms-cp-app:local

# Domain / same-origin entry
PUBLIC_WEB_ORIGIN=https://atslab.top
PUBLIC_API_ORIGIN=https://atslab.top
ALLOWED_CORS_ORIGINS=https://atslab.top
PREVIEW_BASE_URL=https://atslab.top/preview
GITHUB_REDIRECT_URI=https://atslab.top/api/connectors/github/oauth/callback

# Local auth: cloud beta keeps registration closed and seeds one test account.
AUTH_MODE=local
LOCAL_AUTH_REGISTRATION_ENABLED=false
ADMIN_BOOTSTRAP_EMAILS=
CODEX_REAL_USER_TASK_EMAIL_ALLOWLIST=test@atslab.top

# Required secrets. Generate real values on the server; do not commit them.
POSTGRES_PASSWORD=replace-with-32-plus-random-chars
AUTH_SESSION_SECRET=replace-with-32-plus-random-chars
PREVIEW_ACCESS_SECRET=replace-with-32-plus-random-chars
GITHUB_TOKEN_ENCRYPTION_KEY=replace-with-32-plus-random-chars
CONNECTOR_TOKEN_ENCRYPTION_KEY=replace-with-32-plus-random-chars

# Model provider. API key is read from ./secrets/volcengine_api_key.
MODEL_PROVIDER=volcengine
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=doubao-seed-2-1-turbo-260628
MODEL_REQUEST_TIMEOUT_MS=60000
MODEL_BUDGET_CNY=25

# Real local/cloud beta worker gate.
CODEX_WORKER_MODE=container
CODEX_WORKER_INTERVAL_MS=5000
CODEX_REAL_EXECUTION_ENABLED=true
CODEX_REAL_USER_TASKS_ENABLED=true
CODEX_REAL_PREFLIGHT_ONLY=false
CODEX_REAL_COMMAND=/app/scripts/codex-doubao21-exec.sh
CODEX_REAL_TASK_LIMIT_PER_RUN=1
CODEX_REAL_DAILY_BUDGET_TASKS=3
CODEX_REAL_MAX_RUNTIME_MS=600000
CODEX_REAL_AUTO_DISABLE_ON_FAILURE=true
CODEX_OUTPUT_MAX_FILES=200
CODEX_OUTPUT_MAX_BYTES=5242880
CODEX_DOCKER_LOG_MAX_BYTES=65536
CODEX_EXECUTION_IDLE_TIMEOUT_MS=180000
CODEX_EXECUTION_HEARTBEAT_MS=30000
CODEX_DOUBAO_MODEL=doubao-seed-2-1-turbo-260628
CODEX_DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Small-server defaults.
BUILD_MAX_CONCURRENT=1
PREVIEW_BUILD_MODE=fast
WORKSPACE_RETENTION_DAYS=7
PREVIEW_RETENTION_DAYS=14
WORKER_HEARTBEAT_INTERVAL_MS=5000
CODEX_TASK_STALE_MS=900000
BUILD_JOB_STALE_MS=900000

# Optional integrations.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_TOKEN=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
