NODE_ENV=production

# Public origins / Caddy subdomains
PUBLIC_WEB_ORIGIN=https://atoms.example.com
PUBLIC_API_ORIGIN=https://atoms-api.example.com
ALLOWED_CORS_ORIGINS=https://atoms.example.com
PREVIEW_BASE_URL=https://atoms-api.example.com/preview
GITHUB_REDIRECT_URI=https://atoms-api.example.com/api/connectors/github/oauth/callback

# Shared Postgres / Redis, isolated by account + schema/prefix
DATA_STORE=postgres
DATABASE_URL=postgres://atoms_cp_app:change-me@postgres.internal:5432/shared_apps
DATABASE_SCHEMA=atoms_cp
REDIS_URL=redis://redis.internal:6379
REDIS_KEY_PREFIX=atoms_cp:

# Required production secrets, all must be non-default and >= 32 chars
PREVIEW_ACCESS_SECRET=replace-with-32-plus-random-chars
GITHUB_TOKEN_ENCRYPTION_KEY=replace-with-32-plus-random-chars
CONNECTOR_TOKEN_ENCRYPTION_KEY=replace-with-32-plus-random-chars

# Single app image, run as web/api/builder-worker/codex-worker services
ATOMS_APP_IMAGE=ghcr.io/example/atoms-cp-app:latest
WEB_API_PROXY_ORIGIN=

# Small-machine defaults
BUILD_MAX_CONCURRENT=1
CODEX_WORKER_MODE=docker
CODEX_WORKER_INTERVAL_MS=5000
CODEX_DOCKER_IMAGE=node:22-alpine
CODEX_DOCKER_TIMEOUT_MS=120000
CODEX_DOCKER_LOG_MAX_BYTES=65536
CODEX_REAL_EXECUTION_ENABLED=false
CODEX_REAL_COMMAND=
CODEX_DOCKER_NETWORK_MODE=none
CODEX_EXECUTION_IDLE_TIMEOUT_MS=180000
CODEX_EXECUTION_HEARTBEAT_MS=30000
CODEX_OUTPUT_MAX_FILES=200
CODEX_OUTPUT_MAX_BYTES=5242880
CODEX_EXECUTION_ENV_ALLOWLIST=
CODEX_REAL_PREFLIGHT_ONLY=true
CODEX_REAL_CANARY_ENABLED=false
CODEX_REAL_USER_TASKS_ENABLED=false
CODEX_SECRET_MOUNT_PATH=
CODEX_SECRET_FILE=/opt/atoms-cp/secrets/codex_api_key
CODEX_REAL_TASK_LIMIT_PER_RUN=1
CODEX_REAL_DAILY_BUDGET_TASKS=3
CODEX_REAL_MAX_RUNTIME_MS=600000
CODEX_REAL_AUTO_DISABLE_ON_FAILURE=true
CODEX_DOUBAO_MODEL=doubao-seed-2-1-turbo-260628
CODEX_DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
CODEX_TASK_STALE_MS=900000
BUILD_JOB_STALE_MS=900000
INTERNAL_BETA_SMOKE_MODE=deterministic
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKSPACE_RETENTION_DAYS=7
PREVIEW_RETENTION_DAYS=14

# Optional providers/integrations
AUTH_MODE=local
MODEL_PROVIDER=volcengine
DEEPSEEK_API_KEY=
VOLCENGINE_API_KEY_FILE=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=doubao-seed-2-1-turbo-260628
MODEL_REQUEST_TIMEOUT_MS=60000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_TOKEN=
VERCEL_TOKEN=
VERCEL_TEAM_ID=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
